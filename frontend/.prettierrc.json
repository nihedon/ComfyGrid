{
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "all",
    "printWidth": 160,
    "plugins": ["prettier-plugin-svelte", "@trivago/prettier-plugin-sort-imports"],
    "overrides": [
        {
            "files": "*.html",
            "options": {
                "tabWidth": 2
            }
        },
        {
            "files": "*.svelte",
            "options": {
                "tabWidth": 2,
                "parser": "svelte",
                "printWidth": 100
            }
        }
    ],
    "importOrder": ["^svelte$", "^react", "^es-toolkit$", "<THIRD_PARTY_MODULES>", "^@/(.*)", "^[./]"],
    "importOrderSortSpecifiers": true
}
