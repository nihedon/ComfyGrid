{
    "name": "frontend",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "check": "pnpm run check:lint && pnpm run check:format && pnpm run check:svelte && pnpm run check:type && pnpm run check:unused",
        "check:lint": "eslint src/**/*.{ts,svelte}",
        "check:lint-fix": "eslint src/**/*.{ts,svelte} --fix",
        "check:svelte": "svelte-check",
        "check:type": "pnpm exec tsc --noEmit",
        "check:unused": "npx knip",
        "check:format": "prettier --check src",
        "format": "prettier --write 'src/**/*.{ts,js,json,css,svelte,html}'",
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@rollup/plugin-inject": "^5.0.5",
        "@sveltejs/vite-plugin-svelte": "^6.2.1",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/bootstrap": "^5.2.10",
        "@types/jquery": "^4.0.0",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.17.1",
        "globals": "^16.5.0",
        "knip": "^6.15.0",
        "litegraph.js": "^0.7.18",
        "prettier": "^3.6.2",
        "prettier-plugin-svelte": "^3.5.1",
        "rollup-plugin-visualizer": "^7.0.1",
        "sass": "^1.99.0",
        "sass-embedded": "1.93.3",
        "svelte": "5.53.5",
        "svelte-check": "^4.4.6",
        "svelte-eslint-parser": "^1.4.0",
        "typescript": "5.9.3",
        "typescript-eslint": "^8.59.1",
        "vite": "^7.3.2"
    },
    "dependencies": {
        "@popperjs/core": "^2.11.8",
        "bootstrap": "^5.3.8",
